<body class="bg-gray-50 min-h-screen">
    {{> navbar}}

    <div class="container mx-auto px-4 py-6 mt-20">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">Edit Membership</h1>
                <p class="text-gray-600 mt-2">Modify the details for membership #{{membership.activeMembershipId}}</p>
            </div>
            <div class="flex flex-wrap gap-3 mt-4 md:mt-0">
                <a href="/memberships/list" class="bg-gray-600 hover:bg-gray-700 text-white px-5 py-2.5 rounded-lg font-medium flex items-center transition-colors">
                    <i class="fas fa-arrow-left mr-2"></i> Back
                </a>
            </div>
        </div>

        <form id="edit-membership-form" action="/api/memberships/{{membership.activeMembershipId}}" method="POST" class="bg-white rounded-2xl shadow-lg p-6 mb-8 border border-green-100">
            <input type="hidden" name="activeMembershipId" value="{{membership.activeMembershipId}}">

            <div class="mb-8">
                <h2 class="text-xl font-semibold text-gray-800 mb-4">Client Information</h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label class="block text-gray-700 text-sm font-bold mb-2" for="fullName">Full Name *</label>
                        <input type="text" id="fullName" name="fullName" value="{{membership.holderName}}" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg" required>
                    </div>
                    <div>
                        <label class="block text-gray-700 text-sm font-bold mb-2" for="phone">Phone</label>
                        <input type="tel" id="phone" name="phone" value="{{membership.holderPhone}}" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg">
                    </div>
                    <div>
                        <label class="block text-gray-700 text-sm font-bold mb-2" for="email">Email</label>
                        <input type="email" id="email" name="email" value="{{membership.holderEmail}}" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg">
                    </div>
                </div>
            </div>

            <div class="mb-8">
                <h2 class="text-xl font-semibold text-gray-800 mb-4">Membership Information</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-gray-700 text-sm font-bold mb-2" for="status">Status *</label>
                        <select id="status" name="status" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg" required>
                            <option value="Activa" {{#if (eq membership.status "Activa")}}selected{{/if}}>Active</option>
                            <option value="Inactiva" {{#if (eq membership.status "Inactiva")}}selected{{/if}}>Inactive</option>
                            <option value="Vencida" {{#if (eq membership.status "Vencida")}}selected{{/if}}>Expired</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-700 text-sm font-bold mb-2" for="startDate">Start Date *</label>
                        <input type="date" id="startDate" name="startDate" value="{{membership.startDate}}" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg" required>
                    </div>
                    <div>
                        <label class="block text-gray-700 text-sm font-bold mb-2" for="endDate">End Date *</label>
                        <input type="date" id="endDate" name="endDate" value="{{membership.endDate}}" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg" required>
                    </div>
                    <div>
                        <label class="block text-gray-700 text-sm font-bold mb-2" for="finalPrice">Final Price *</label>
                        <input type="number" id="finalPrice" name="finalPrice" value="{{membership.finalPrice}}" step="0.01" min="0" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg" required>
                    </div>
                </div>
            </div>

            {{#if (gt membership.maxMembers 1)}}
            <div class="mb-8">
                <h2 class="text-xl font-semibold text-gray-800 mb-4">Members</h2>
                <div id="members-container" class="space-y-4">
                    {{#each membership.members}}
                    <div class="member-item flex items-center space-x-2">
                        <input type="text" name="members" value="{{this.fullName}}" class="flex-1 w-full px-3 py-2 border border-gray-300 rounded-md" required>
                        <button type="button" class="remove-member-btn bg-red-500 text-white px-3 py-2 rounded-md">Remove</button>
                    </div>
                    {{/each}}
                </div>
                 <button type="button" id="add-member-btn" class="mt-2 bg-green-600 text-white px-3 py-2 rounded-md">Add Member</button>
            </div>
            {{/if}}

            <div class="flex justify-end space-x-3 pt-6 border-t border-gray-200">
                <a href="/memberships/list" class="px-4 py-2 border rounded-md">Cancel</a>
                <button type="submit" class="px-4 py-2 bg-green-600 text-white rounded-md">Save Changes</button>
            </div>
        </form>
    </div>

    <script src="/js/moduleMembershipJs/membershipEditForm.js"></script>
</body>