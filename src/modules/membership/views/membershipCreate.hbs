{{>navbar}}

<body class="bg-green-50 min-h-screen p-6">
    <div class="max-w-2xl mx-auto bg-white rounded-lg shadow-md overflow-hidden mt-20 border border-green-200">
        <!-- Client Form -->
        <div class="p-6 border-b border-green-200">
            <h1 class="text-2xl font-bold text-green-800">Create Client</h1>
            <form id="client-form" action="/api/memberships/client" method="POST" class="mt-4 space-y-4">
                <div>
                    <label class="block text-sm font-medium text-green-700">Full Name</label>
                    <input type="text" name="fullName" required
                        class="mt-1 block w-full px-3 py-2 border border-green-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500">
                </div>
                <div>
                    <label class="block text-sm font-medium text-green-700">Phone</label>
                    <input type="text" name="phone"
                        class="mt-1 block w-full px-3 py-2 border border-green-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500">
                </div>
                <div>
                    <label class="block text-sm font-medium text-green-700">Email</label>
                    <input type="email" name="email" required
                        class="mt-1 block w-full px-3 py-2 border border-green-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500">
                </div>
                <button type="submit"
                    class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                    Register Client
                </button>
                <div id="client-message" class="hidden text-sm font-medium"></div>
            </form>
        </div>

        <!-- Membership Form -->
        <div class="p-6">
            <h1 class="text-2xl font-bold text-green-800">Create Membership</h1>
            <form id="membership-form" action="/api/memberships" method="POST" class="mt-4 space-y-4">
                <input type="hidden" id="clientId" name="clientId" value="">

                <div>
                    <label class="block text-sm font-medium text-green-700">Membership Type:</label>
                    <select id="membershipType" name="membershipTypeId" required
                        class="mt-1 block w-full px-3 py-2 border border-green-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500">
                        {{#each membershipTypes}}
                        <option value="{{membershipTypeId}}" data-max-members="{{maxMembers}}" data-price="{{price}}">
                            {{name}} - ${{price}}
                        </option>
                        {{/each}}
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-green-700">Start Date:</label>
                    <input type="date" id="startDate" name="startDate" required
                        class="mt-1 block w-full px-3 py-2 border border-green-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500">
                </div>

                <div>
                    <label class="block text-sm font-medium text-green-700">End Date:</label>
                    <input type="date" id="endDate" name="endDate" readonly
                        class="mt-1 block w-full px-3 py-2 border border-green-300 rounded-md shadow-sm bg-green-50">
                </div>

                <input type="hidden" id="finalPrice" name="finalPrice" value="">

                <div id="members-section" class="hidden mt-4 p-4 border border-green-200 rounded-md bg-green-50">
                    <h4 class="text-sm font-medium text-green-700 mb-2">Family Members</h4>
                    <div id="members-container" class="space-y-2"></div>
                    <button type="button" id="add-member-btn"
                        class="mt-2 inline-flex items-center px-3 py-1 border border-transparent text-xs font-medium rounded-md text-green-700 bg-green-100 hover:bg-green-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                        ➕ Add Member
                    </button>
                </div>

                <div>
                    <label class="block text-sm font-medium text-green-700">Payment Method:</label>
                    <select id="paymentMethod" name="paymentMethodId" required
                        class="mt-1 block w-full px-3 py-2 border border-green-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500">
                        <option value="">Select a payment method</option>
                        {{#each paymentMethods}}
                        <option value="{{paymentMethodId}}">{{name}}</option>
                        {{/each}}
                    </select>
                </div>

                <div class="mt-4">
                    <label class="block text-sm font-medium text-green-700">Final Price:</label>
                    <input type="text" id="final-price-display" readonly
                        class="mt-1 block w-full px-3 py-2 border border-green-300 rounded-md shadow-sm bg-green-50">
                </div>

                {{#if isAdmin}}
                <div class="flex items-end space-x-2">
                    <div class="flex-1">
                        <label class="block text-sm font-medium text-green-700">Discount (%):</label>
                        <input type="number" id="discount" name="discount" min="0" max="100" value="0"
                            class="mt-1 block w-full px-3 py-2 border border-green-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500">
                    </div>
                    <button type="button" id="apply-discount-btn"
                        class="px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                        Apply
                    </button>
                </div>
                {{/if}}

                <button type="submit" id="submit-membership-btn" disabled
                    class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-gray-400 hover:bg-gray-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-400">
                    Create Membership (complete client form first)
                </button>

                <div id="membership-message" class="hidden text-sm font-medium"></div>
            </form>
        </div>
    </div>

    <!-- Client Confirmation Modal -->
    <div id="client-modal"
        class="fixed inset-0 bg-black bg-opacity-50 max-h-[80vh] overflow-y-auto items-center justify-center hidden z-50">
        <div class="bg-white rounded-lg p-6 w-full max-w-md">
            <h3 class="text-lg font-bold text-green-800 mb-4">Confirm Client Data</h3>
            <div id="client-modal-content" class="mb-4 space-y-2"></div>
            <div class="flex justify-end space-x-3">
                <button id="cancel-client-btn"
                    class="px-4 py-2 text-sm text-gray-600 hover:text-gray-800">Cancel</button>
                <button id="confirm-client-btn"
                    class="px-4 py-2 bg-green-600 text-white rounded-md text-sm hover:bg-green-700">Confirm</button>
            </div>
        </div>
    </div>

    <!-- Membership Confirmation Modal -->
    <div id="membership-modal"
        class="fixed inset-0 bg-black bg-opacity-50 max-h-[80vh] overflow-y-auto items-center justify-center hidden z-50">
        <div class="bg-white rounded-lg p-6 w-full max-w-md max-h-[80vh] overflow-y-auto">
            <h3 class="text-lg font-bold text-green-800 mb-4">Confirm Membership</h3>
            <div id="membership-modal-content" class="mb-4 space-y-2"></div>
            <div class="flex justify-end space-x-3">
                <button id="cancel-membership-btn"
                    class="px-4 py-2 text-sm text-gray-600 hover:text-gray-800">Cancel</button>
                <button id="confirm-membership-btn"
                    class="px-4 py-2 bg-green-600 text-white rounded-md text-sm hover:bg-green-700">Confirm</button>
            </div>
        </div>
    </div>

    <script src="/js/moduleMembershipJs/membershipForm.js"></script>
</body>