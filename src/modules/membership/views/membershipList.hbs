<body class="bg-gray-50 min-h-screen">
    {{>navbar}}

    <div class="container mx-auto px-4 py-6 mt-20">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">{{title}}</h1>
            </div>
            <div class="flex flex-wrap gap-3 mt-4 md:mt-0">
                <a href="/memberships/create" class="bg-green-600 hover:bg-green-700 text-white px-5 py-2.5 rounded-lg font-medium flex items-center">
                    <i class="fas fa-plus-circle mr-2"></i> New Membership
                </a>
                {{#if isAdmin}}
                <a href="/memberships/reports" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg font-medium flex items-center">
                    <i class="fas fa-chart-line mr-2"></i> Generate Reports
                </a>
                {{/if}}
            </div>
        </div>

        <!-- Filters and Search -->
        <div class="bg-white rounded-2xl shadow-lg p-6 mb-8 border border-gray-200">
            <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-5">
                <div class="flex-1">
                    <label class="block text-gray-700 text-sm font-semibold mb-2">Quick Search</label>
                    <input type="text" id="search-input" placeholder="Search by name, phone, or email..." class="w-full pl-10 pr-4 py-3 border rounded-xl">
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-gray-700 text-sm font-semibold mb-2">Status Filter</label>
                        <select id="status-filter" class="w-full px-4 py-3 border rounded-xl">
                            <option value="all">All Memberships</option>
                            <option value="Active">Active</option>
                            <option value="Due">Expiring Soon</option>
                            <option value="Expired">Expired</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-700 text-sm font-semibold mb-2">Sort By</label>
                        <select id="sort-by" class="w-full px-4 py-3 border rounded-xl">
                            <option value="expiry">Expiry Date</option>
                            <option value="recent">Most Recent</option>
                            <option value="name">Alphabetical</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Membership Table -->
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase">Member</th>
                            <th class="px-4 py-4 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
                            <th class="px-4 py-4 text-left text-xs font-medium text-gray-500 uppercase">Dates</th>
                            <th class="px-4 py-4 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                            <th class="px-4 py-4 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200" id="memberships-table-body">
                        <!-- Rows will be injected by client-side JS -->
                    </tbody>
                </table>
            </div>
            <div id="pagination-controls" class="px-6 py-4 bg-gray-50 border-t">
                <!-- Pagination will be handled by client-side JS -->
            </div>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="delete-modal" class="fixed inset-0 bg-black bg-opacity-50 items-center justify-center z-50 hidden">
        <div class="bg-white rounded-lg p-6 w-full max-w-md">
            <h3 class="text-xl font-semibold text-gray-800">Confirm Deletion</h3>
            <p class="text-gray-600 my-4">Are you sure you want to delete this membership? This action cannot be undone.</p>
            <div class="flex justify-end space-x-3">
                <button id="cancel-delete-btn" class="px-4 py-2 border rounded-lg">Cancel</button>
                <button id="confirm-delete-btn" class="px-4 py-2 bg-red-600 text-white rounded-lg">Delete</button>
            </div>
        </div>
    </div>

    <script src="/js/moduleMembershipJs/membershipList.js"></script>
</body>